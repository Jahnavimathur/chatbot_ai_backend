# Database settings
# Uses SQLite as default, you can override it here if needed:
# DATABASE_URL=sqlite:///./chatbot_ai.db

# Security settings
SECRET_KEY=your_super_secret_key_here
# You can generate a good secret key with: openssl rand -hex 32

# OpenAI Settings for Chatbot AI
OPENAI_API_KEY=sk-your_actual_openai_api_key_here

# Database settings (Replace with your actual database URL if different)
# Or it will use the default PyMySQL connection from the code
# DATABASE_URL=mysql+pymysql://root:@localhost:3306/chatbot_ai

# Security settings
SECRET_KEY=your_super_secret_key_here
# You can generate a good secret key with: openssl rand -hex 32

# OpenAI Settings for Chatbot AI
OPENAI_API_KEY=sk-your_actual_openai_api_key_here
